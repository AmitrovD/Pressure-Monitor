<Window x:Class="PressureMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PressureMonitor.Converters"
        xmlns:model="clr-namespace:PressureMonitor.Models"
        mc:Ignorable="d"
        Title="Settings" Height="160" Width="320"
        >
    <Window.Resources> 
        <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>


        <RadioButton GroupName="GenerationStrategy" Content="Static" Grid.Column="0" Grid.Row="0"
                     IsChecked="{Binding SelectedType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Static}"/>
        <RadioButton GroupName="GenerationStrategy" Content="Random" Grid.Column="0" Grid.Row="1"
                     IsChecked="{Binding SelectedType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Random}"/>
        <RadioButton GroupName="GenerationStrategy" Content="Linear" Grid.Column="0" Grid.Row="2"
                     IsChecked="{Binding SelectedType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Linear}"/>

        <TextBox x:Name="StaticTextBox"
         Grid.Column="1"
         Grid.Row="0"
         FontSize="18"
         Visibility="{Binding StaticVisibility}"
         ToolTip="Введите уровень статического давления">

            <TextBox.Text>
                <Binding Path="StaticValue"
                 UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <conv:PositiveNumberRule />
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>

        </TextBox>

        <TextBox x:Name="RandomTextBox"
         Grid.Column="1"
         Grid.Row="1"
         FontSize="18"
         Visibility="{Binding RandomVisibility}"
         ToolTip="Введите лимит случайного давления">

            <TextBox.Text>
                <Binding Path="RandomValue"
                 UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <conv:PositiveNumberRule />
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>

        </TextBox>

        <TextBox x:Name="LinearStepTextBox"
         Grid.Column="1"
         Grid.Row="2"
         FontSize="18"
         Visibility="{Binding LinearVisibility}"
         ToolTip="Введите шаг изменения уровня давления">

            <TextBox.Text>
                <Binding Path="LinearStartValue"
                 UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <conv:PositiveNumberRule />
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>

        </TextBox>

        <TextBox x:Name="LinearStartTextBox"
         Grid.Column="2"
         Grid.Row="2"
         FontSize="18"
         Visibility="{Binding LinearVisibility}"
         ToolTip="Введите изначальный уровень давления">

            <TextBox.Text>
                <Binding Path="LinearStep"
                 UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <conv:PositiveNumberRule />
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>

        </TextBox>

        <ComboBox Grid.Column="3" Grid.Row="2"
                  Visibility="{Binding DirectionVisibility}"
                  ItemsSource="{Binding PressureDirections}" 
                  SelectedItem="{Binding SelectedDirection}"
                  ToolTip="Выберите направление изменения давления"
                  />

    </Grid>
</Window>
