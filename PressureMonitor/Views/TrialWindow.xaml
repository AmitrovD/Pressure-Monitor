<Window x:Class="PressureMonitor.Views.TrialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PressureMonitor.Views"
        xmlns:conv="clr-namespace:PressureMonitor.Converters"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="Trials" Height="500" Width="900">
    <Window.Resources>
        <conv:PointsToPlotModelConverter x:Key="PointsToPlotModel"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <ComboBox Width="150" Margin="0,0,8,0"
                  ItemsSource="{Binding SortDirectionsOptions}"
                  SelectedItem="{Binding SelectedSortDirections}"/>
            <Button Content="Сортировать" Width="100"
                Command="{Binding SortCommand}"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Trials}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕"
                                Width="24" Height="24"
                                Foreground="Red"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding DataContext.DeleteCommand, 
                                          RelativeSource={RelativeSource AncestorType=ListView}}"
                                CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="Название" Width="200"
                                DisplayMemberBinding="{Binding Name}"/>
                    
                    <GridViewColumn Header="Дата" Width="150"
                                DisplayMemberBinding="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>
                    
                    <GridViewColumn Header="График" Width="350">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <oxy:PlotView Height="150" Width="330"
                                          IsEnabled="False"
                                          Model="{Binding Points, 
                                          Converter={StaticResource PointsToPlotModel}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>